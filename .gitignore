# 忽略 Node.js 套件
mitofates-web/node_modules/
npm-debug.log*

# 忽略上傳暫存檔
mitofates-web/uploads/*
!mitofates-web/uploads/.gitkeep

# 任務執行結果 (忽略所有生成的 JSON，保留 .gitkeep)
mitofates-web/results/*.json
!mitofates-web/results/.gitkeep

# 忽略 Perl 執行過程產生的暫存檔
MitoFates/script/bin/modules/_Inline/

# 忽略系統雜物
.DS_Store
Thumbs.db

*/.vscode/*
